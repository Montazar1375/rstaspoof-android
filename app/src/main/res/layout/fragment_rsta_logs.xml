<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rsta_terminal_background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/rsta_terminal_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/padding_spacing_dp16"
        android:paddingVertical="@dimen/padding_spacing_dp8">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="SNI-Ray"
            android:textColor="@color/rsta_terminal_cursor"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:text=" — proxy@android"
            android:textColor="@color/rsta_terminal_dim"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="@string/rsta_logs_auto_scroll"
            android:textColor="@color/rsta_terminal_dim"
            android:textSize="11sp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_auto_scroll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_spacing_dp8"
            app:theme="@style/BrandedSwitch" />

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="@dimen/padding_spacing_dp8"
        android:layout_weight="1"
        android:background="@color/rsta_terminal_surface">

        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:padding="@dimen/padding_spacing_dp16"
            android:text="@string/rsta_logs_waiting"
            android:textColor="@color/rsta_terminal_dim"
            android:textSize="11sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="10dp"
            android:paddingVertical="@dimen/padding_spacing_dp8"
            android:scrollbars="vertical"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
